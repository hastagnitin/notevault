# ================================================================
# NoteVault Server — Environment Variables
# ================================================================
# 1. Copy this file:  Copy-Item .env.example .env
# 2. Fill in real credentials — NEVER commit .env
# ================================================================

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ── Anthropic Claude API ──────────────────────────────────────
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── Supabase Configuration ──────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR-PROJECT/settings/api
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── AI APIs ───────────────────────────────────────────────────
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Get from: https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=nvapi-your_nvidia_key
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Local Ollama (no key needed, runs locally)
OLLAMA_MODEL=gemma:2b

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000       # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_WINDOW_MS=60000     # 1 minute
AI_RATE_LIMIT_MAX_REQUESTS=20
