rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    // Each user can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Notes ──────────────────────────────────────────────────────────────
    // A note is owned by the user whose uid matches the stored userId field.
    match /notes/{noteId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;

      // Allow the owner to create a new note (resource doesn't exist yet).
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
    }

    // ── Chats ──────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
    }

    // ── Quizzes ────────────────────────────────────────────────────────────
    // Any authenticated user can read quizzes (useful for shared study rooms).
    // Only owner can create or update.
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // ── Study Rooms ────────────────────────────────────────────────────────
    // Read/write allowed only if the authenticated user is a participant.
    match /studyRooms/{roomId} {
      allow read, write: if request.auth != null
                         && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
    }
  }
}
