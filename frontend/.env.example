# ================================================================
# NoteVault Frontend — Environment Variables
# ================================================================
# 1. Copy this file:  Copy-Item .env.example .env
# 2. Fill in the values from your service dashboards
# ================================================================

# ── Supabase Client Config ─────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Backend API URL ────────────────────────────────────────────
# For local development: http://localhost:5000/api
# For production: your_deployed_backend_url/api
VITE_API_URL=http://localhost:5000/api

# ── Firebase Config (Optional - for Auth) ──────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
